{
  "name": "markview",
  "version": "1.0.0",
  "description": "A native macOS markdown viewer and editor built with Electron",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/dkeg/markview.git"
  },
  "author": "dkeg",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "dependencies": {
    "codemirror": "^5.65.16",
    "marked": "^4.3.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.markview.app",
    "productName": "MarkView",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon-dark.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "fileAssociations": [
        { "ext": "md", "name": "Markdown File", "role": "Editor" },
        { "ext": "json", "name": "JSON File", "role": "Editor" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "node_modules/codemirror/**",
      "assets/**"
    ]
  }
}
